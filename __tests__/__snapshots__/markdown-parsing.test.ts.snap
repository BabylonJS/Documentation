          children: ["\\n", _jsxDEV(_components.li, {
            children: ["FitStrategy.NONE Default. By default the HTML element will have a width and height that fill the viewport while respecting the aspect ratio of the element and then will be scaled down to fit the HtmlMesh size specified in ", _jsxDEV(_components.code, {
              children: "setContent"
            }, undefined, false, {
